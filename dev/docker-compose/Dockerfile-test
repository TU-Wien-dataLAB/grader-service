FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv
COPY pyproject.toml .
RUN uv pip install --system -e .

COPY . .

WORKDIR /app

CMD ["pytest", "tests/integration", "-v"]
