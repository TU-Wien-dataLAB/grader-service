FROM python:3.13-slim

# Install git and sqlite
RUN apt-get update && \
    apt-get install -y git sqlite3 && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:0.9.3 /uv /uvx /bin/
ENV UV_SYSTEM_PYTHON=true

# Install watchdog for hot-reload
RUN uv pip install watchdog

WORKDIR /app

# Install dependencies
COPY ./pyproject.toml ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --no-install-project

# Install service in editable mode
COPY ./packages/service/pyproject.toml ./packages/service/
COPY ./packages/service/grader_service ./packages/service/grader_service
RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --link-mode=copy -e ./packages/service

# Set default branch to main and default user
RUN git config --global init.defaultBranch main && \
    git config --global user.name "Your Name" && \
    git config --global user.email "youremail@example.com"

WORKDIR /app/service_dir
EXPOSE 4010

CMD ["grader-service", "-f", "/app/grader_service_config.py"]
